            ],
            "url": {
              "raw": "{{base_url}}/jobs/1/interviews",
              "host": ["{{base_url}}"],
              "path": ["jobs", "1", "interviews"]
            }
          }
        },
        {
          "name": "Update Interview",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"round_type\": \"Phone Screen - Rescheduled\",\n  \"date_time\": \"2024-03-21T14:00:00\",\n  \"notes\": \"Rescheduled due to conflict\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/interviews/1",
              "host": ["{{base_url}}"],
              "path": ["interviews", "1"]
            }
          }
        },
        {
          "name": "Delete Interview",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/interviews/1",
              "host": ["{{base_url}}"],
              "path": ["interviews", "1"]
            }
          }
        }
      ]
    },
