{
  "info": {
    "name": "ATS Backend-Farhan Features",
    "description": "Postman collection for all new backend-farhan features",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Feature 1: Job Sorting",
      "item": [
        {
          "name": "Get Sorted Dashboard - By Company (ASC)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/dashboard/sorted?sort_by=company&order=asc",
              "host": ["{{base_url}}"],
              "path": ["dashboard", "sorted"],
              "query": [
                {
                  "key": "sort_by",
                  "value": "company"
                },
                {
                  "key": "order",
                  "value": "asc"
                }
              ]
            }
          }
        },
        {
          "name": "Get Sorted Dashboard - By Last Activity (DESC)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/dashboard/sorted?sort_by=last_activity&order=desc",
              "host": ["{{base_url}}"],
              "path": ["dashboard", "sorted"],
              "query": [
                {
                  "key": "sort_by",
                  "value": "last_activity"
                },
                {
                  "key": "order",
                  "value": "desc"
                }
              ]
            }
          }
        },
        {
          "name": "Get Sorted Dashboard - By Deadline (ASC)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/dashboard/sorted?sort_by=deadline&order=asc",
              "host": ["{{base_url}}"],
              "path": ["dashboard", "sorted"],
              "query": [
                {
                  "key": "sort_by",
                  "value": "deadline"
                },
                {
                  "key": "order",
                  "value": "asc"
                }
              ]
            }
          }
        },
        {
          "name": "Get Sorted Dashboard - By Created At (DESC)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/dashboard/sorted?sort_by=created_at&order=desc",
              "host": ["{{base_url}}"],
              "path": ["dashboard", "sorted"],
              "query": [
                {
                  "key": "sort_by",
                  "value": "created_at"
                },
                {
                  "key": "order",
                  "value": "desc"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Feature 2: Interview Tracking",
      "item": [
        {
          "name": "Create Interview",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"job_id\": 1,\n  \"round_type\": \"Phone Screen\",\n  \"date_time\": \"2024-03-20T14:00:00\",\n  \"notes\": \"Initial screening with recruiter\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/jobs/1/interviews",
              "host": ["{{base_url}}"],
              "path": ["jobs", "1", "interviews"]
            }
          }
        },
        {
          "name": "List Interviews for Job",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
